+inline bool openUrl(const QUrl &url) {
+  if (!url.isValid()) return false;
+  const QString scheme = url.scheme().toLower();
+  if (scheme == QStringLiteral("http") || scheme == QStringLiteral("https")) {
+    return QDesktopServices::openUrl(url);
+  }
+  return false;
+}
